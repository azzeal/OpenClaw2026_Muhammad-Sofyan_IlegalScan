# Copy to .env.local and fill in.

# Database — any Postgres URL. Tested with local Postgres, Vercel Postgres, Supabase, and Neon.
DATABASE_URL="postgres://user:pass@host:5432/clearmark_platform"

# Auth.js — generate a random 32+ char secret. `openssl rand -base64 32` works.
AUTH_SECRET="REPLACE_WITH_LONG_RANDOM_STRING"
NEXTAUTH_URL="http://localhost:3001"

# DOKU MCP / API (Fase D — required for payment subscriptions)
# DOKU_CLIENT_ID=""
# DOKU_SECRET_KEY=""
# DOKU_ENV="sandbox"  # or "production"
# DOKU_WEBHOOK_SECRET=""

# Cron auth — Vercel calls /api/cron/scan with `Authorization: Bearer ${CRON_SECRET}`
CRON_SECRET="REPLACE_WITH_LONG_RANDOM_STRING_FOR_CRON_AUTH"

# Telegram notifications (Fase E)
# TELEGRAM_BOT_TOKEN=""

# Optional — paid scrapers if we ever upgrade beyond free-tier HTTP
# SCRAPERAPI_KEY=""
